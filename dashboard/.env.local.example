# WorkOS AuthKit Configuration
# Get these from https://dashboard.workos.com/
# Docs: https://workos.com/docs/authkit/nextjs

# Your WorkOS Client ID (found in API Keys)
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXX

# Your WorkOS API Key (found in API Keys)
# Use sk_test_ for development, sk_live_ for production
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXX

# Cookie password for session encryption (must be 32+ characters)
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your-secure-32-character-password-here

# Redirect URI after OAuth callback
# IMPORTANT: Must match exactly what's configured in WorkOS Dashboard
# Development: http://localhost:3000/auth/callback
# Production: https://whatsapp-agent-dashboard.<account>.workers.dev/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Worker URL for WebSocket connections (Phase 2 - Real-time updates)
# NEXT_PUBLIC_WORKER_URL=https://whatsapp-ai-agent.<account>.workers.dev

# ============================================
# PRODUCTION DEPLOYMENT NOTES:
# ============================================
# For Cloudflare Workers deployment, set these as secrets:
#   npx wrangler secret put WORKOS_CLIENT_ID
#   npx wrangler secret put WORKOS_API_KEY
#   npx wrangler secret put WORKOS_COOKIE_PASSWORD
#   npx wrangler secret put NEXT_PUBLIC_WORKOS_REDIRECT_URI
#
# Remember to:
# 1. Add production redirect URI to WorkOS Dashboard
# 2. Use production API key (sk_live_...) in production
# 3. Generate a secure WORKOS_COOKIE_PASSWORD for production
