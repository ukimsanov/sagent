{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "whatsapp-ai-agent",
	"account_id": "568051052fcb248c756d306dece6cfb7",
	"main": "src/index.ts",
	"compatibility_date": "2025-11-27",
	"observability": {
		"enabled": true
	},

	// Environment variables (non-sensitive)
	"vars": {
		"WHATSAPP_VERIFY_TOKEN": "91db3f26164e50a81ab66d4ca057957e198f1ceb7856c713898a7bd9a2846a06"
	},

	// D1 Database for business data, products, leads
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "whatsapp-ai-agent-db",
			"database_id": "7f289e64-10ef-47cb-b27e-376d81ad2366"
		}
	],

	// KV Namespace for conversation history and sessions
	"kv_namespaces": [
		{
			"binding": "CONVERSATIONS",
			"id": "d2cf96c706c14823813c1d5f957ef63e"
		}
	]

	// Secrets (set via `wrangler secret put`):
	// - OPENAI_API_KEY
	// - WHATSAPP_ACCESS_TOKEN
	// - WHATSAPP_PHONE_NUMBER_ID
}